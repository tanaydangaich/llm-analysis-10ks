OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=10k-filings
# Local Neo4j Desktop: bolt://localhost:7687, user neo4j
# AuraDB: neo4j+s://<id>.databases.neo4j.io — user is the INSTANCE ID, not neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
# Optional: gate the Streamlit UI behind a shared password (used in deployment)
# APP_PASSWORD=...
